@{
    ViewData["Title"] = "Contacts";
}

<div class="cm-page">
    <div class="cm-header">
        <div>
            <h1 class="cm-title">My Contacts</h1>
            <span class="cm-count" id="contactCount">0 contacts</span>
        </div>
        <div class="d-flex gap-2">
            <button id="btnDeleteSelected" class="btn cm-btn-delete-many d-none">
                Delete Selected
            </button>
            <button id="btnAddContact" class="btn cm-btn-add">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" class="me-1">
                    <path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4"/>
                </svg>
                Add Contact
            </button>
        </div>
    </div>

    <div class="cm-search-wrap">
        <svg class="cm-search-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
            <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.099zm-5.242 1.656a5.5 5.5 0 1 1 0-11 5.5 5.5 0 0 1 0 11"/>
        </svg>
        <input type="text" id="searchInput" class="form-control cm-search" placeholder="Search by name or email..." />
    </div>

    <div id="alertContainer" class="mt-2"></div>

    <div id="contactsContainer">
        <div class="cm-empty" id="loadingState">
            <div class="cm-spinner spinner-border text-secondary" role="status"></div>
            <p class="mt-2 text-muted">Loading contacts...</p>
        </div>

        <div class="cm-empty d-none" id="emptyState">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="#ccc" viewBox="0 0 16 16">
                <path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0"/>
                <path fill-rule="evenodd" d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8m8-7a7 7 0 0 0-5.468 11.37C3.242 11.226 4.805 10 8 10s4.757 1.225 5.468 2.37A7 7 0 0 0 8 1"/>
            </svg>
            <p class="mt-3 text-muted">No contacts yet. Add your first one!</p>
        </div>

        <table class="table cm-table d-none" id="contactsTable">
            <thead>
                <tr>
                    <th style="width:40px;">
                        <input type="checkbox" class="form-check-input" id="selectAll" />
                    </th>
                    <th style="width:48px;"></th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th style="width:80px;"></th>
                </tr>
            </thead>
            <tbody id="contactsBody"></tbody>
        </table>
    </div>
</div>

<!-- Add / Edit Modal -->
<div class="modal fade" id="contactModal" tabindex="-1" aria-labelledby="contactModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content cm-modal">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-semibold" id="contactModalLabel">Add Contact</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="contactForm" novalidate>
                    <input type="hidden" id="contactId" />
                    <div class="mb-3">
                        <label for="contactName" class="form-label fw-medium">Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="contactName" maxlength="100" placeholder="Full name" />
                        <div class="invalid-feedback" id="nameError"></div>
                    </div>
                    <div class="mb-3">
                        <label for="contactEmail" class="form-label fw-medium">Email <span class="text-danger">*</span></label>
                        <input type="email" class="form-control" id="contactEmail" maxlength="200" placeholder="email@example.com" />
                        <div class="invalid-feedback" id="emailError"></div>
                    </div>
                    <div class="mb-1">
                        <label for="contactPhone" class="form-label fw-medium">Phone</label>
                        <input type="tel" class="form-control" id="contactPhone" maxlength="20" placeholder="Optional" />
                    </div>
                </form>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn cm-btn-add px-4" id="btnSave">Save</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/contacts.js" asp-append-version="true"></script>
}
