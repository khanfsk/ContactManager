@{
    ViewData["Title"] = "Contacts";
}

<div class="container mt-4">
    <div class="row mb-3 align-items-center">
        <div class="col-md-4">
            <h2 class="mb-0">Contacts</h2>
        </div>
        <div class="col-md-5">
            <input type="text" id="searchInput" class="form-control" placeholder="Search by name or email..." />
        </div>
        <div class="col-md-3 text-end">
            <button id="btnAddContact" class="btn btn-primary">+ Add Contact</button>
        </div>
    </div>

    <div id="alertContainer"></div>

    <table class="table table-hover">
        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th style="width: 150px;">Actions</th>
            </tr>
        </thead>
        <tbody id="contactsBody">
            <tr>
                <td colspan="4" class="text-center text-muted">Loading...</td>
            </tr>
        </tbody>
    </table>
</div>

<!-- Add / Edit Modal -->
<div class="modal fade" id="contactModal" tabindex="-1" aria-labelledby="contactModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="contactModalLabel">Add Contact</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="contactForm" novalidate>
                    <input type="hidden" id="contactId" />
                    <div class="mb-3">
                        <label for="contactName" class="form-label">Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="contactName" maxlength="100" />
                        <div class="invalid-feedback" id="nameError"></div>
                    </div>
                    <div class="mb-3">
                        <label for="contactEmail" class="form-label">Email <span class="text-danger">*</span></label>
                        <input type="email" class="form-control" id="contactEmail" maxlength="200" />
                        <div class="invalid-feedback" id="emailError"></div>
                    </div>
                    <div class="mb-3">
                        <label for="contactPhone" class="form-label">Phone</label>
                        <input type="tel" class="form-control" id="contactPhone" maxlength="20" />
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="btnSave">Save</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/contacts.js" asp-append-version="true"></script>
}
